# Required: PocketOption auth string from browser DevTools (Network -> WS)
PO_SSID='42["auth",{"session":"YOUR_SESSION_ID","isDemo":1,"uid":0,"platform":1}]'

# Optional: Demo mode (1=demo, 0=live)
PO_IS_DEMO=1

# Optional: Cache TTL in seconds (default 10)
SIGNAL_CACHE_TTL_SEC=10

# Optional: Background refresh interval in seconds (default 5)
SIGNAL_REFRESH_INTERVAL_SEC=5

# Optional: Default candle count for signal calculation (default 150)
SIGNAL_DEFAULT_CANDLE_COUNT=150

# Optional: Comma-separated tracked assets (default: major OTC pairs + gold/silver)
# SIGNAL_TRACKED_ASSETS=EURUSD_otc,GBPUSD_otc,XAUUSD_otc

# Optional: Comma-separated tracked timeframes (default 1m,5m)
# SIGNAL_TRACKED_TIMEFRAMES=1m,5m

# Optional: Candle fetch timeout in seconds (default 15)
# SIGNAL_CANDLE_TIMEOUT_SEC=15

# Optional: Reconnection attempts (default 3)
# SIGNAL_RECONNECT_ATTEMPTS=3
