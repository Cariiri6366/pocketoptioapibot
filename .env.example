# Required: PocketOption auth string from browser DevTools (Network -> WS)
PO_SSID='42["auth",{"session":"YOUR_SESSION_ID","isDemo":1,"uid":0,"platform":1}]'

# Optional: Demo mode (1=demo, 0=live)
PO_IS_DEMO=1

# Optional: Cache TTL in seconds (default 5 - for instant responses)
SIGNAL_CACHE_TTL_SEC=5

# Optional: Background refresh interval in seconds (default 3 - professional bot feel)
SIGNAL_REFRESH_INTERVAL_SEC=3

# Optional: Max seconds to wait for live calculation in request (default 3 - never block)
# SIGNAL_LIVE_REQUEST_TIMEOUT_SEC=3

# Optional: Default candle count for signal calculation (default 150)
SIGNAL_DEFAULT_CANDLE_COUNT=150

# Optional: Comma-separated tracked assets (default: EURUSD, USDJPY, GBPUSD for fast cycles)
# SIGNAL_TRACKED_ASSETS=EURUSD_otc,USDJPY_otc,GBPUSD_otc

# Optional: Comma-separated tracked timeframes (default 1m,5m)
# SIGNAL_TRACKED_TIMEFRAMES=1m,5m

# Optional: Candle fetch timeout in seconds (default 30 - PocketOption can be slow after cold start)
# SIGNAL_CANDLE_TIMEOUT_SEC=30

# Optional: Reconnection attempts (default 3)
# SIGNAL_RECONNECT_ATTEMPTS=3

# ---------------------------------------------------------------------------
# Firestore (optional - for signal persistence and fallback)
# ---------------------------------------------------------------------------
# Enable Firestore integration (default false)
# ENABLE_FIRESTORE=true

# Full service account JSON as string (required when ENABLE_FIRESTORE=true)
# Get from Firebase Console -> Project Settings -> Service Accounts -> Generate new key
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Write signal history for direction/confidence changes (default true)
# FIRESTORE_WRITE_HISTORY=true

# Min seconds between history writes per asset:timeframe (default 60)
# HISTORY_WRITE_INTERVAL_SEC=60

# Max age in seconds for Firestore latest_signals fallback (default 300)
# FIRESTORE_LATEST_TTL_SEC=300
